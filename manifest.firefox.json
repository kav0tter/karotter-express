{
  "manifest_version": 2,
  "name": "karotter Shortcuts",
  "version": "1.0.0",
  "description": "karotter.com にキーボードショートカットを追加します。設定ページからキー割り当てを変更できます。",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "karotter-shortcuts@szk27",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage"],
  "sidebar_action": {
    "default_panel": "options.html",
    "default_title": "karotter Shortcuts 設定",
    "default_icon": "icons/icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["https://karotter.com/*", "https://www.karotter.com/*"],
      "js": [
        "defaults.js",
        "selectors.js",
        "help-overlay.js",
        "content-script.js"
      ],
      "css": ["help-overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
