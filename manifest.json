{
  "manifest_version": 3,
  "name": "karotter Express",
  "version": "1.0.0",
  "description": "karotter.com を高速操作できるキーボードショートカット拡張機能。Vim風、Twitter風プリセット、カスタマイズ可能なキーバインド。",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "sidePanel"],
  "side_panel": {
    "default_path": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://karotter.com/*", "https://www.karotter.com/*", "https://karotter.jp/*", "https://www.karotter.jp/*", "https://karotter.karon.jp/*", "https://www.karotter.karon.jp/*"],
      "js": [
        "defaults.js",
        "storage.js",
        "selectors.js",
        "help-overlay.js",
        "inline-hints.js",
        "floating-panel.js",
        "content-script.js"
      ],
      "css": ["help-overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
