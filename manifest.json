{
  "manifest_version": 3,
  "name": "karotter Shortcuts",
  "version": "1.0.0",
  "description": "karotter.com にキーボードショートカットを追加します。設定ページからキー割り当てを変更できます。",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "sidePanel"],
  "side_panel": {
    "default_path": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://karotter.com/*", "https://www.karotter.com/*"],
      "js": [
        "defaults.js",
        "selectors.js",
        "help-overlay.js",
        "inline-hints.js",
        "floating-panel.js",
        "content-script.js"
      ],
      "css": ["help-overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
